{
  "name": "AI不够酷新闻视频模板V4",
  "description": "支持多种标题风格和圆角背景",
  "version": "4.0",
  "resolution": "1080x1920",
  "fps": 30,
  "total_duration": 12,
  
  "fixed_elements": {
    "background_image": "assets/backgrounds/ai_not_cool_bg.jpg",
    "background_color": "#1A1A1A",
    "brand_name": "AI不够酷",
    "brand_logo": "assets/logos/ai_not_cool_logo.jpg",
    "brand_position": "top_center",
    "brand_font_size": 48,
    "brand_color": "#FFFFFF",
    "brand_bold": true
  },
  
  "title_section": {
    "enabled": true,
    "position": "top_center",
    "y_position": 150,
    "main_title": {
      "font_size": 72,
      "color": "#FFFFFF",
      "max_chars_per_line": 12,
      "margin_left": 100,
      "margin_right": 100,
      "auto_wrap": true,
      "bold": true,
      "stroke_width": 0,
      "stroke_color": "#000000",
      "content_key": "main_title",
      "style": "style1"
    },
    "sub_title": {
      "font_size": 48,
      "color": "#000000",
      "max_chars_per_line": 16,
      "auto_wrap": true,
      "bold": true,
      "margin_top": 10,
      "content_key": "sub_title",
      "style": "yellow_bg_black_text",
      "tight_layout": true
    }
  },
  
  "image_carousel": {
    "enabled": true,
    "image_count": 3,
    "each_duration": 3,
    "image_style": {
      "width_percent": 100,
      "height_percent": 40,
      "y_position": 550,
      "object_fit": "cover",
      "border_radius": 0
    },
    "transition": {
      "type": "zoom_in",
      "duration": 0.5
    },
    "content_key": "images"
  },
  
  "text_sections": {
    "enabled": true,
    "section_count": 3,
    "each_duration": 3,
    "position": "bottom_center",
    "y_position": 1350,
    "height": 400,
    "style": {
      "font_size": 48,
      "color": "#FFFFFF",
      "max_chars_per_line": 16,
      "auto_wrap": true,
      "bold": true,
      "stroke_width": 0,
      "stroke_color": "#000000",
      "background": {
        "enabled": true,
        "color": "#000000",
        "opacity": 0.7,
        "padding": 25,
        "border_radius": 20,
        "style": "black_bg_white_text"
      }
    },
    "content_key": "text_sections"
  },
  
  "styles": {
    "style1": {
      "name": "黑色圆角背景+白色字体",
      "background_color": "#000000",
      "background_opacity": 0.7,
      "text_color": "#FFFFFF",
      "border_radius": 20,
      "padding": 25
    },
    "style2": {
      "name": "黑色圆角背景+绿色字体",
      "background_color": "#000000",
      "background_opacity": 0.7,
      "text_color": "#00FF00",
      "border_radius": 20,
      "padding": 25
    },
    "style3": {
      "name": "黄色圆角背景+黑色字体",
      "background_color": "#FFD700",
      "background_opacity": 0.9,
      "text_color": "#000000",
      "border_radius": 20,
      "padding": 25
    },
    "yellow_bg_black_text": {
      "name": "黄色圆角背景+黑色加粗字体",
      "background_color": "#FFD700",
      "background_opacity": 0.9,
      "text_color": "#000000",
      "border_radius": 20,
      "padding": 20
    },
    "black_bg_white_text": {
      "name": "黑色圆角背景+白色字体",
      "background_color": "#000000",
      "background_opacity": 0.7,
      "text_color": "#FFFFFF",
      "border_radius": 20,
      "padding": 25
    }
  },
  
  "outro": {
    "enabled": true,
    "duration": 3,
    "position": "bottom_center",
    "font_size": 40,
    "color": "#CCCCCC",
    "bold": false,
    "content_key": "outro_text"
  },
  
  "audio": {
    "bgm": "assets/music/ai_not_cool_bgm.mp3",
    "volume": 0.3,
    "fade_in": 0.5,
    "fade_out": 1
  }
}
